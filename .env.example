# ─── Brokz Astro — environment template ────────────────────────────
# Copy to `.env` (or `.env.production`) and fill in once the matching
# account has been created + domain ownership verified.
#
# All variables prefixed PUBLIC_ are embedded at build time and shipped
# to the browser. Only put non-secret tokens here.

# ─── Tracking & verification ─────────────────────────────────────────
# Google Search Console — get token at https://search.google.com/search-console
# after claiming brokztech.com. Paste just the content attribute value,
# e.g. "abc123def456..."
PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools — https://www.bing.com/webmasters
PUBLIC_BING_VERIFICATION=

# Yandex Webmaster (relevant for TR market share)
# https://webmaster.yandex.com
PUBLIC_YANDEX_VERIFICATION=

# Google Tag Manager container ID — RECOMMENDED entry point.
# Once GTM is live, GA4 + Meta Pixel + LinkedIn Insight + any future pixel
# goes INSIDE GTM with no further code deploys. Format: "GTM-XXXXXXX"
# https://tagmanager.google.com
PUBLIC_GTM_ID=

# Google Analytics 4 — used as a direct fallback ONLY when GTM_ID is unset.
# If you wire GTM, add GA4 as a tag inside GTM instead. Format: "G-XXXXXXXXXX"
# https://analytics.google.com
PUBLIC_GA4_ID=

# Microsoft Clarity — free heatmap + session recording. Drops in raw.
# https://clarity.microsoft.com
PUBLIC_CLARITY_ID=

# ─── Supabase — Auth, Database, Edge Functions ─────────────────────
# Project URL (public, client-safe). Dashboard → Settings → API.
# Format: https://<project-ref>.supabase.co
PUBLIC_SUPABASE_URL=

# Anon key (public, client-safe). RLS policies gate what it can see.
PUBLIC_SUPABASE_ANON_KEY=

# SERVICE ROLE KEY — bypasses RLS. Server-only. NEVER ship to the
# client bundle. Used exclusively by Astro server endpoints and
# Supabase Edge Functions (e.g. admin-invite-user).
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used to verify Supabase-issued tokens server-side
# (e.g. when validating access tokens outside of @supabase/ssr helpers).
# Dashboard → Settings → API → JWT Settings.
SUPABASE_JWT_SECRET=

# ─── Resend (optional — mirrors repo-root .env.example) ────────────
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=
# CONTACT_FROM_EMAIL=

# ─── Supabase Edge Functions — CORS ────────────────────────────────
# Comma-separated list of origins allowed to call Edge Functions
# (e.g. contact-lead-capture). Set in Supabase dashboard, NOT here —
# this line documents the expected var for reference.
# ALLOWED_ORIGINS=http://localhost:4321,https://brokztech.com

# ─── Supabase Edge Functions — Admin endpoints ─────────────────────
# Documentation only — these are set in the Supabase dashboard (per
# Edge Function → Secrets), not in the Astro build.
#
# PUBLIC_SITE_URL — absolute base URL the Edge Functions use to compose
#   links back into the app (invite accept, invoice view, ticket
#   permalinks). No trailing slash.
# PUBLIC_SITE_URL=http://localhost:4321
#
# CONTACT_FROM_EMAIL — Resend sender (same key as contact form).
# CONTACT_FROM_EMAIL=noreply@brokztech.com
#
# CONTACT_TO_EMAIL — fallback admin inbox for ticket notifications and
#   contact-form leads.
# CONTACT_TO_EMAIL=brokztech@gmail.com
