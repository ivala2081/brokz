---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import NavBar from '../components/NavBar.tsx';
import ProductsPageContent from '../components/ProductsPageContent.tsx';
import { getT } from '../i18n/t';
import { service, breadcrumbList } from '../lib/jsonld';

const t = getT('en', 'products');
const pathname = '/products';
const jsonLd = [
    service({
        name: t('seo.title'),
        description: t('seo.description'),
        path: pathname,
        serviceType: 'Fintech software products',
    }),
    breadcrumbList([
        { name: 'Home',         path: '/' },
        { name: t('hero.label'), path: pathname },
    ]),
];
---
<BaseLayout
  title={t('seo.title')}
  description={t('seo.description')}
  keywords={t('seo.keywords')}
  jsonLd={jsonLd}
>
  <NavBar client:load />
  <main class="min-h-screen bg-surface">
    <ProductsPageContent client:load />
  </main>
  <Footer />
</BaseLayout>
