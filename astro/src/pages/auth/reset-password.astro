---
import AuthLayout from '../../layouts/AuthLayout.astro';
import ResetPasswordForm from '../../components/auth/ResetPasswordForm.tsx';
import { getT, localeFromPath } from '../../i18n/t';

const locale = localeFromPath(Astro.url.pathname);
const t = getT(locale, 'auth');
---
<AuthLayout title={t('resetPassword.seoTitle')} description={t('resetPassword.seoDescription')}>
  <ResetPasswordForm locale={locale} client:load />
</AuthLayout>
