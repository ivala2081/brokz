---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import NavBar from '../../components/NavBar.tsx';
import LegalLandingContent from '../../components/LegalLandingContent.tsx';
import { getT } from '../../i18n/t';
import { breadcrumbList } from '../../lib/jsonld';

const t = getT('en', 'legal');
const pathname = '/legal';
const jsonLd = breadcrumbList([
    { name: 'Home',                path: '/' },
    { name: t('landing.hero.label'), path: pathname },
]);
---
<BaseLayout
  title={t('seo.title')}
  description={t('seo.description')}
  keywords={t('seo.keywords')}
  jsonLd={jsonLd}
>
  <NavBar client:load />
  <main class="min-h-screen bg-surface">
    <LegalLandingContent client:load />
  </main>
  <Footer />
</BaseLayout>
