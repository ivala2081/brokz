---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import NavBar from '../../components/NavBar.tsx';
import AboutPageContent from '../../components/AboutPageContent.tsx';
import { getT } from '../../i18n/t';
import { breadcrumbList } from '../../lib/jsonld';

const t = getT('tr', 'about');
const pathname = '/tr/hakkimizda';
const jsonLd = breadcrumbList([
    { name: 'Ana Sayfa',      path: '/tr' },
    { name: t('hero.label'),   path: pathname },
]);
---
<BaseLayout
  title={t('seo.title')}
  description={t('seo.description')}
  keywords={t('seo.keywords')}
  jsonLd={jsonLd}
>
  <NavBar client:load />
  <main class="min-h-screen bg-surface">
    <AboutPageContent client:load />
  </main>
  <Footer />
</BaseLayout>
