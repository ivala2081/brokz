---
import AuthLayout from '../../layouts/AuthLayout.astro';
import UpdatePasswordForm from '../../components/auth/UpdatePasswordForm.tsx';
import { getT, localeFromPath } from '../../i18n/t';

const locale = localeFromPath(Astro.url.pathname);
const t = getT(locale, 'auth');
---
<AuthLayout title={t('updatePassword.seoTitle')} description={t('updatePassword.seoDescription')}>
  <UpdatePasswordForm locale={locale} client:load />
</AuthLayout>
