---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import NavBar from '../../components/NavBar.tsx';
import BlogIndexContent from '../../components/BlogIndexContent.tsx';
import { breadcrumbList, collectionPage } from '../../lib/jsonld';

const title = 'Blog | Brokz — Fintech Engineering Insights';
const description = 'Technical deep-dives, industry analysis, product updates, and company news from the Brokz engineering team.';
const jsonLd = [
    collectionPage('Brokz Blog', description, '/blog'),
    breadcrumbList([
        { name: 'Home', path: '/' },
        { name: 'Blog', path: '/blog' },
    ]),
];
---
<BaseLayout
  title={title}
  description={description}
  keywords="brokerage technology blog, fintech engineering, MT5 development, trading infrastructure, algo trading"
  canonical="/blog"
  jsonLd={jsonLd}
>
  <NavBar client:load />
  <main class="min-h-screen bg-surface">
    <BlogIndexContent client:load />
  </main>
  <Footer />
</BaseLayout>
